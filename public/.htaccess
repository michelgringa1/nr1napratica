# =========================================================
#  NR1 na Prática — .htaccess (Apache / Hostinger)
#  Vai junto com o conteúdo de dist/ para public_html/
# =========================================================

# ---- Redirect de afiliado (link cloaking) ----
# /vai/formacao -> link real com o ref intacto.
# 302 temporário evita que o Google memorize o destino externo como canônico.
Redirect 302 /vai/formacao https://lp.camargoizabella.com.br/formacao-gestor-de-nr1?ref=B106168547F
Redirect 302 /vai/formacao/ https://lp.camargoizabella.com.br/formacao-gestor-de-nr1?ref=B106168547F

# ---- Força HTTPS + www -> não-www ----
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Força HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Remove www (padroniza em nr1napratica.online)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# ---- Página de erro 404 amigável ----
ErrorDocument 404 /404.html

# ---- Compressão (gzip) ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# ---- Compressão (brotli, se disponível) ----
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# ---- Cache de estáticos ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  # HTML com cache curto (permite atualizar conteúdo rapidamente)
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# ---- Segurança básica de headers ----
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # Cache imutável para assets com hash
  <FilesMatch "\.(css|js|woff2|svg|webp|png|jpg|jpeg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
