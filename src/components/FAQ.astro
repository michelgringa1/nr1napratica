---
export interface FaqItem {
  q: string;
  a: string; // pode conter HTML simples
}
export interface Props {
  items: FaqItem[];
  heading?: string;
}
const { items, heading = 'Perguntas frequentes' } = Astro.props;
---
<section class="faq" id="faq" aria-label={heading}>
  <h2>{heading}</h2>
  {items.map((item, i) => (
    <details open={i === 0}>
      <summary>{item.q}</summary>
      <div class="faq-body" set:html={item.a} />
    </details>
  ))}
</section>
