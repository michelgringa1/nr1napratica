---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site';
import { breadcrumbSchema } from '../data/schema';

const title = 'Contato';
const description = `Entre em contato com o ${SITE.name} — sugestões, correções e parcerias.`;
const schemas = [breadcrumbSchema([['Início', '/'], ['Contato', '/contato/']])];
// Troque pelo seu e-mail real de contato.
const email = 'contato@nr1napratica.online';
---
<Base title={title} description={description} schemas={schemas}>
  <div class="page-hero">
    <div class="container">
      <p class="kicker">Contato</p>
      <h1>Fale com o {SITE.name}</h1>
    </div>
  </div>

  <article class="container article">
    <p class="lead">
      Tem uma sugestão, encontrou uma informação desatualizada ou quer propor uma
      parceria? Será um prazer receber sua mensagem.
    </p>

    <div class="fact-box">
      <h3 class="mt-0">E-mail</h3>
      <p style="margin:0;">
        <a href={`mailto:${email}`}><strong>{email}</strong></a>
      </p>
      <p style="margin:0.6em 0 0;font-size:0.92rem;">
        Respondemos correções sobre a NR-1 e nossas análises com prioridade —
        precisão é parte do nosso compromisso editorial.
      </p>
    </div>

    <p>
      <small class="muted">
        Nota para o editor do site: atualize o e-mail acima em
        <code>src/pages/contato.astro</code>. Se quiser um formulário, é possível
        integrar um serviço externo (ex.: Formspree) mantendo o site estático.
      </small>
    </p>
  </article>
</Base>
